{
  "name": "expo-crypto-argon2",
  "version": "0.0.0",
  "description": "Argon2id key derivation function for React Native via Expo Modules",
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "ios",
    "android",
    "c-argon2/src",
    "c-argon2/include",
    "ExpoCryptoArgon2.podspec",
    "expo-module.config.json"
  ],
  "engines": {
    "npm": "=10.x",
    "node": "=24.x"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "validate": "pnpm run check && pnpm run build:check",
    "check": "biome check --write",
    "check:ci": "biome ci",
    "build:check": "tsc --noEmit true",
    "build": "tsc"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "expo-modules-core": ">=1.12.0"
  },
  "keywords": [
    "react-native",
    "expo",
    "argon2",
    "argon2id",
    "crypto",
    "kdf",
    "key-derivation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "typescript": "^5.1.3"
  }
}
