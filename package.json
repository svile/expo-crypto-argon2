{
  "name": "expo-crypto-argon2",
  "version": "0.0.0",
  "description": "Argon2id key derivation function for React Native via Expo Modules",
  "license": "MIT",
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "ios",
    "android",
    "c-argon2/src",
    "c-argon2/include",
    "ExpoCryptoArgon2.podspec",
    "expo-module.config.json"
  ],
  "engines": {
    "npm": "=10.x",
    "node": "=24.x"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "validate": "pnpm run check && pnpm run build:check && pnpm run test:coverage",
    "check": "biome check --write",
    "check:ci": "biome ci",
    "build:check": "tsc --noEmit true",
    "build": "tsc",
    "test:coverage": "vitest run --coverage",
    "test": "vitest",
    "prepublishOnly": "git submodule update --init --recursive"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "react-native",
    "expo",
    "argon2",
    "argon2id",
    "crypto",
    "kdf",
    "key-derivation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/inntend/expo-crypto-argon2"
  },
  "bugs": {
    "url": "https://github.com/inntend/expo-crypto-argon2/issues"
  },
  "homepage": "https://github.com/inntend/expo-crypto-argon2/"
}
